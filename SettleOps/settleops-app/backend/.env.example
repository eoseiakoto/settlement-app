# SettleOps Backend Configuration
# Copy this file to .env and customize values as needed

# Flask Environment
FLASK_ENV=development
FLASK_DEBUG=True

# Server Configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=5000

# Data Configuration
DATA_DIR=/sessions/upbeat-kind-goodall/mnt/SettleOps/VSS_Reports/310323
USE_DATABASE=False
DATABASE_URL=sqlite:///settleops.db

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# File Upload
MAX_CONTENT_LENGTH=524288000  # 500MB in bytes

# API Configuration
API_PREFIX=/api
API_VERSION=v1
